{
  "name": "deck-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Mission Deck hub — local-first backend for tasks, Obsidian, and AI",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "mcp": "tsx mcp/server.ts",
    "eval": "tsx eval/run.ts",
    "reindex": "tsx -e \"import('./src/rag.js').then(async r=>{console.log(await r.reindexTasks());console.log(await r.reindexNotes());})\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.0.0",
    "undici": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
