# ── Deck Server config ───────────────────────────────────────────────
# Copy to .env and fill in. Secrets live here, never in the frontend.

PORT=8787

# ── Obsidian Local REST API plugin ──
# Settings → Local REST API → copy the API key.
OBSIDIAN_API_KEY=
# Plain HTTP (recommended) on 27123 needs no cert. Set false to use HTTPS 27124.
OBSIDIAN_USE_HTTP=true
OBSIDIAN_HTTP_URL=http://127.0.0.1:27123
OBSIDIAN_HTTPS_URL=https://127.0.0.1:27124
# Fallback daily-notes folder (the /periodic/daily/ endpoint is used first).
OBSIDIAN_DAILY_FOLDER=Daily Notes
# Extra files to scan for tasks, comma-separated (daily note is automatic).
OBSIDIAN_FILES=

# ── Local model (Ollama) — the default for parsing/embeddings ──
OLLAMA_URL=http://127.0.0.1:11434
# Recommended: a tool-capable instruct model, e.g. `ollama pull qwen2.5` or llama3.1.
# mistral works but is weaker at classification and tool use.
OLLAMA_CHAT_MODEL=qwen2.5
OLLAMA_EMBED_MODEL=nomic-embed-text
# Let the local model run the agent tool-loop (search/create/complete/save).
# Needs a tool-capable model (qwen2.5 / llama3.1). Leave false for mistral.
OLLAMA_TOOLS=false

# ── RAG tuning ──
RAG_HYBRID=true          # fuse vector + keyword (Obsidian) search — best for exact identifiers
RAG_HYDE=false           # hypothetical-doc query expansion (adds one local LLM call per search)
RAG_REINDEX_MINUTES=15   # background incremental reindex; 0 to disable

# ── Claude (opt-in escalation for hard reasoning) ──
# Leave ANTHROPIC_API_KEY blank to keep everything 100% local.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
